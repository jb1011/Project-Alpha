# Arc
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
# Platform / manager (also Factory owner). v1 may be a local key.
PLATFORM_PRIVATE_KEY=0x
# Addresses (defaults exist in addresses.arc-testnet.json; env overrides win)
IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
USDC_ADDRESS=0x3600000000000000000000000000000000000000
FACTORY_ADDRESS=0x
# Roles (guardian only needs an address during onboarding)
GUARDIAN_ADDRESS=0x
# Operator signer — pick ONE:
#  (a) Turnkey enclave key (PRODUCTION, non-custodial): set the TURNKEY_* block below incl. TURNKEY_SIGN_WITH.
#  (b) Local key (testnet/dev fallback): OPERATOR_PRIVATE_KEY. Turnkey wins if both are set.
OPERATOR_PRIVATE_KEY=0x
# Storage
DATA_DIR=./data
# Turnkey operator (production, non-custodial). Set all four to use TurnkeySigner:
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
TURNKEY_ORGANIZATION_ID=
TURNKEY_SIGN_WITH=        # the operator wallet ADDRESS (or private-key id) provisioned in Turnkey
TURNKEY_BASE_URL=https://api.turnkey.com
# Per-agent vault: backend-owned delegated API keypair (P-256). Generate once
# (e.g. @turnkey/crypto generateP256KeyPair). Embedded in every agent sub-org,
# scoped sign-only per-sub-org by policy. PRIVATE key is a secret — keep in .env only.
TURNKEY_DELEGATED_API_PUBLIC_KEY=
TURNKEY_DELEGATED_API_PRIVATE_KEY=
# Circle (thin; optional)
CIRCLE_API_KEY=

# Track C — ERC-8183 jobs
# Job contract address (proxy) on Arc testnet
JOB_CONTRACT_ADDRESS=0x0747EEf0706327138c69792bF28Cd525089e4583
# Reputation registry address on Arc testnet
REPUTATION_REGISTRY_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713
# Job client private key (signs on-chain job interactions); defaults to PLATFORM_PRIVATE_KEY if unset
JOB_CLIENT_PRIVATE_KEY=0x
# Job evaluator private key (signs evaluations); required for live job runs; must differ from the provider
JOB_EVALUATOR_PRIVATE_KEY=0x
# Sweep unpaid balances to treasury (true/false; defaults to false)
JOB_SWEEP_TO_TREASURY=false
# Opt-in gate for live job e2e test
# ARC_JOB_LIVE=1
